                                "success": {
                                    "type": "number",
                                    "example": 1
                                },
                                "data": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "token": {
                                                "type": "string",
                                                "example": "jwt_token"
