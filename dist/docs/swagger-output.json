        "/auth/create-guest": {
            "post": {
                "tags": [
                    "1.Auth"
                ],
                "summary": "Create Guest User",
                "description": "Create temporary guest account",
                "parameters": [
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "device_id": {
                                    "type": "string",
                                    "example": "ANDROID_123456"
                                },
                                "country": {
                                    "type": "string",
                                    "example": "India"
                                },
                                "food_type": {
                                    "type": "string",
                                    "example": "nonveg"
                                },
                                "prefer_lang": {
                                    "type": "string",
                                    "example": "en"
                                }
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Guest Created",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "success": {
                                    "type": "number",
                                    "example": 1
                                },
                                "data": {
                                    "type": "object",
                                    "properties": {
                                        "user_id": {
                                            "type": "string",
                                            "example": "TEMP_1750000000000"
                                        }
                                    }
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Guest Created"
                                }
                            },
                            "xml": {
                                "name": "main"
                            }
                        }
                    }
                }
            }
        },
        "/auth/request-otp": {
            "post": {
                "tags": [
                    "1.Auth"
                ],
                "summary": "Request OTP",
                "description": "Send OTP to email address",
                "parameters": [
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "email": {
                                    "type": "string",
                                    "example": "test@gmail.com"
                                },
                                "type": {
                                    "type": "string",
                                    "example": "1"
                                }
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OTP Sent Successfully",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "success": {
                                    "type": "number",
                                    "example": 1
                                },
                                "data": {
                                    "type": "array",
                                    "example": [],
                                    "items": {}
                                },
                                "message": {
                                    "type": "string",
                                    "example": "OTP Sent Successfully"
                                }
                            },
                            "xml": {
                                "name": "main"
                            }
                        }
                    },
                    "400": {
                        "description": "Validation Error",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "success": {
                                    "type": "number",
                                    "example": 0
                                },
                                "data": {
                                    "type": "array",
                                    "example": [],
                                    "items": {}
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Email is required"
                                }
                            },
                            "xml": {
                                "name": "main"
                            }
                        }
                    }
                }
            }
        },
        "/auth/verify-otp": {
            "post": {
                "tags": [
                    "1.Auth"
                ],
                "summary": "Verify OTP",
                "description": "Verify OTP",
                "parameters": [
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "email": {
                                    "type": "string",
                                    "example": "test@gmail.com"
                                },
                                "otp": {
                                    "type": "string",
                                    "example": "1234"
                                }
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OTP Veified Successfully",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "success": {
                                    "type": "number",
                                    "example": 1
                                },
                                "data": {
                                    "type": "array",
                                    "example": [],
                                    "items": {}
                                },
                                "message": {
                                    "type": "string",
                                    "example": "OTP Verified Successfully"
                                }
                            },
                            "xml": {
                                "name": "main"
                            }
                        }
                    }
                }
            }
        },
        "/auth/signup": {
            "post": {
                "tags": [
                    "1.Auth"
                ],
                "summary": "Sign UP",
                "description": "User Signup by email ",
                "parameters": [
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "user_name": {
                                    "type": "string",
                                    "example": "kamalesh"
                                },
                                "email": {
                                    "type": "string",
                                    "example": "abc@gmail.com"
                                },
                                "password": {
                                    "type": "string",
                                    "example": "12345678"
                                },
                                "device_id": {
                                    "type": "string",
                                    "example": "Android1234"
                                },
                                "device_type": {
                                    "type": "string",
                                    "example": "android or IOs"
                                },
                                "device_token": {
                                    "type": "string",
                                    "example": "FCM12345"
                                }
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User Sign up Successfully",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "success": {
                                    "type": "number",
                                    "example": 1
                                },
                                "data": {
                                    "type": "array",
                                    "example": [],
                                    "items": {}
                                },
                                "message": {
                                    "type": "string",
                                    "example": "User Sign up Successfully"
                                }
                            },
                            "xml": {
                                "name": "main"
                            }
                        }
                    }
                }
            }
        },
        "/auth/login": {
            "post": {
                "tags": [
                    "1.Auth"
                ],
                "summary": "User Login",
                "description": "Login using email and password",
                "parameters": [
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "email": {
                                    "type": "string",
                                    "example": "abc@gmail.com"
                                },
                                "password": {
                                    "type": "string",
                                    "example": "12345678"
                                },
                                "device_id": {
                                    "type": "string",
                                    "example": "android_12345"
                                },
                                "device_type": {
                                    "type": "string",
                                    "example": "android"
                                },
                                "device_token": {
                                    "type": "string",
                                    "example": "FCM12345"
                                }
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Login Successful",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "success": {
                                    "type": "number",
                                    "example": 1
                                },
                                "data": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "token": {
                                                "type": "string",
                                                "example": "jwt_token"
                                            }
                                        }
                                    }
                                },
                                "message": {
                                    "type": "string",
                                    "example": "Login successful"
                                }
                            },
                            "xml": {
                                "name": "main"
                            }
                        }
                    }
                }
            }
        },
